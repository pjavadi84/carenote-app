# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (Whisper)
OPENAI_API_KEY=your_openai_api_key

# Resend (Email)
RESEND_API_KEY=your_resend_api_key
RESEND_DOMAIN=kinroster.com

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_ID=your_stripe_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Cron (manual trigger of /api/cron/weekly-summaries)
CRON_SECRET=your_cron_secret

# Inngest (background jobs — production cron + future durable workflows)
# Get these from https://app.inngest.com after creating an app.
# Local dev does not require these; run `npx inngest-cli@latest dev` instead.
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vapi (live voice calls)
VAPI_API_KEY=your_vapi_private_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id
VAPI_WEBHOOK_SECRET=any_random_string_matching_vapi_dashboard
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
